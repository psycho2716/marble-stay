SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Optional: admin seeder (`npm run seed:admin`) — defaults match supabase/seed.sql
ADMIN_SEED_EMAIL=admin@marblestay.local
ADMIN_SEED_PASSWORD=admin1234

JWT_SECRET=change-me-in-production

GOOGLE_MAPS_API_KEY=your-google-maps-api-key

FRONTEND_ORIGIN=http://localhost:3000
PORT=4000

# Optional: Google AI (Gemini) for personalized hotel recommendations (guest “For you” page)
GEMINI_API_KEY=
# e.g. gemini-3-flash-preview | gemini-2.5-flash
GEMINI_MODEL=gemini-3-flash-preview
# Personalized responses are cached 12h per guest in Supabase (migration: personalized_recommendation_cache).

